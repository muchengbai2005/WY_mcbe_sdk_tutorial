                    "max_height": 200,   // 必填：选取的最大高度，支持molang字符串。如果超过自定义维度的最大高度，则进游戏时会弹出断言窗口
                    "pool": [   // 必填：填充的方块池，根据权重，对选中的区域进行填充
                        {
                            "fill_block": "minecraft:diamond_block",   // "fill_block"是填充的方块名称，支持附加值（看看怎么输入才可以识别）
                            "weight": 10   // "weight"是填充的方块的生成权重
                        },
                        {
                            "fill_block": "minecraft:gold_block",
                            "weight": 10
                        },
                        {
