{
	"format_version": "1.10.0",
	"minecraft:block": {
		"description": {
			"identifier": "customblocks:customblocks_flower_extend",
			"category": "custom"
		},
		"components": {
            //------------相比与customblocks_model_flower新增的逻辑-----------
			"netease:on_entity_inside": {
				"send_python_event": true
			},
			"netease:block_properties": {
				"properties": [
					"breaks_when_fallen_on_by_heavy"
				]
			},
            //---------------------------------------------------------------
			"minecraft:block_light_absorption":{
				"value": 0
			},
			"minecraft:block_light_emission": {
				"emission": 1.0
			},
			"netease:aabb": {
				"collision": {
					"min": [0.0, 0.0, 0.0],
					"max": [0.0, 0.0, 0.0]
				},
				"clip": {
					"min": [0.3, 0.0, 0.3],
					"max": [0.7, 0.63, 0.7]
				}
			},
			"netease:may_place_on": {
				"block": ["minecraft:dirt", "minecraft:grass"],
				"block_state": [
					{
						"name": "minecraft:wool",
						"states": {
							"color": "orange"
						}
					},
					{
						"name": "minecraft:wool",
						"states": {
							"color": "red"
						}
					}
				],
				"spawn_resources": true
			},
			"netease:render_layer": {
				"value": "alpha"
			},
			"netease:solid": {
				"value": false
			},
			"netease:pathable": {
				"value": true
			}
		}
	}
}