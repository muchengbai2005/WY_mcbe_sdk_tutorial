            "minecraft:jump.dynamic": {},
            "minecraft:can_climb": {},
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:behavior.hurt_by_target": {
                "priority": 1
            },
            "minecraft:behavior.python_custom:avoid_tnt": {
                "priority": 2,
